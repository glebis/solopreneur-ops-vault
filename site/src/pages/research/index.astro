---
import Base from '../../layouts/Base.astro';
import Card from '../../components/Card.astro';
---

<Base title="Research">
  <article>
    <h1>Research</h1>
    <p class="subtitle" style="font-size: 1.2rem; font-style: italic; color: var(--color-text-muted);">
      Agent-generated research, human-reviewed. All sources linked.
    </p>

    <div class="card-grid full-width">
      <Card title="Berlin Solopreneur 2026" status="research" tags={["market", "germany"]} href="/research/berlin-solopreneur">
        <p>Visa requirements, tax structure, cost of living, legal entities, banking for international clients.</p>
      </Card>

      <Card title="AI Education Market" status="research" tags={["market", "pricing"]} href="/research/ai-education-market">
        <p>Global market size, cohort-based course pricing, competitive landscape, distribution channels.</p>
      </Card>

      <Card title="LinkedIn Strategy" status="research" tags={["sales", "content"]} href="/research/linkedin-strategy">
        <p>Algorithm insights, content types, lead generation tactics, weekly schedule for solo educators.</p>
      </Card>

      <Card title="Human-Agent Interaction" status="research" tags={["meta", "ux"]} href="/research/hai-landscape">
        <p>Frameworks for human-agent collaboration, UX patterns, trust calibration, anti-patterns.</p>
      </Card>
    </div>

    <p style="margin-top: 2rem; font-style: italic; color: var(--color-text-muted);">
      Research notes are generated by AI agents and reviewed for accuracy.
      Dates and sources are preserved. Treat as starting points, not final answers.
    </p>
  </article>
</Base>
