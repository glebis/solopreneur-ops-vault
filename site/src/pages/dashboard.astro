---
import Base from '../layouts/Base.astro';
import Sparkline from '../components/Sparkline.astro';
import VaultQuery from '../components/VaultQuery.astro';
---

<Base title="Dashboard">
  <article>
    <h1>Dashboard</h1>
    <p class="subtitle" style="font-size: 1.2rem; font-style: italic; color: var(--color-text-muted);">
      Max 5 items. One takes 5 minutes. One is already done.
    </p>

    <h2>Today's Focus</h2>
    <VaultQuery
      from="tasks"
      where={{ status: "open" }}
      fields={["title", "stage", "effort", "priority", "source"]}
      sortBy="priority"
      sortDir="asc"
      limit={5}
      display="cards"
    />

    <h2>Completed</h2>
    <VaultQuery
      from="tasks"
      where={{ status: "done" }}
      fields={["title", "stage", "source"]}
      sortBy="created"
      sortDir="desc"
      limit={5}
      display="table"
    />

    <h2>By Sales Cycle Stage</h2>
    <VaultQuery
      from="tasks"
      fields={["title", "status", "effort", "source"]}
      sortBy="stage"
      groupBy="stage"
      display="list"
    />

    <h2>All Research</h2>
    <VaultQuery
      from="research"
      fields={["title", "domain", "status"]}
      sortBy="title"
      sortDir="asc"
      display="cards"
    />

    <h2>How It Works</h2>

    <p>
      This dashboard mirrors Obsidian's Dataview queries. Tasks and research notes
      live as markdown files with YAML frontmatter. In Obsidian, Dataview renders them
      dynamically. Here, the same files are parsed at build time via <code>VaultQuery</code>.
    </p>

    <pre><code>{`<!-- Astro equivalent of Dataview TABLE -->
<VaultQuery
  from="tasks"
  where={{ status: "open", source: "agent" }}
  fields={["title", "stage", "effort"]}
  sortBy="priority"
  limit={5}
  display="cards"
/>`}</code></pre>

    <p>
      One source of truth. Two interfaces. Vault updates → site rebuilds → dashboard refreshes.
    </p>
  </article>
</Base>
