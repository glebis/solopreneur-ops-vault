---
import '../styles/tufte.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Solopreneur Ops — Agent-powered daily operations for independent educators' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — Solopreneur Ops</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <header class="site-header">
    <a href="/" class="site-title">Solopreneur Ops</a>
    <nav class="site-nav">
      <a href="/dashboard">Dashboard</a>
      <a href="/frameworks">Frameworks</a>
      <a href="/research">Research</a>
      <a href="/agents">Agents</a>
      <a href="/start">Get Started</a>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <p>Built with Obsidian + Claude Code + Astro. Published from a personal vault.</p>
    <p>Berlin, 2026. <a href="https://linkedin.com/in/glebkalinin">Gleb Kalinin</a></p>
  </footer>
</body>
</html>
